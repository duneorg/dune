{
  "name": "@dune/core",
  "version": "0.25.1",
  "license": "MIT",
  "author": "zumbrunn (https://zumbrunn.com)",
  "exports": {
    ".": "./src/mod.ts",
    "./cli": "./src/cli.ts",
    "./plugins": "./src/plugins/mod.ts",
    "./sections": "./src/sections/mod.ts",
    "./theme-helpers": "./src/theme-helpers/mod.ts",
    "./content": "./src/content/api.ts",
    "./content/types": "./src/content/types.ts",
    "./content/path-utils": "./src/content/path-utils.ts",
    "./content/page-loader": "./src/content/page-loader.ts",
    "./mcp": "./src/mcp/mod.ts",
    "./db": "./src/db/mod.ts",
    "./auth/api-guard": "./src/auth/api-guard.ts",
    "./auth/authz": "./src/auth/authz.ts",
    "./auth/authz-adapter-local": "./src/auth/authz-adapter-local.ts",
    "./auth/authz-adapter-db": "./src/auth/authz-adapter-db.ts",
    "./email": "./src/email/mod.ts",
    "./ui": "./src/ui/mod.ts",
    "./ui/editable": "./src/ui/editable/mod.ts",
    "./inline-edit": "./src/inline-edit/mod.ts",
    "./logger": "./src/core/logger.ts",
    "./engine": "./src/core/engine.ts",
    "./hooks": "./src/hooks/types.ts",
    "./config": "./src/config/types.ts",
    "./storage": "./src/storage/mod.ts",
    "./staging": "./src/staging/engine.ts",
    "./workflow": "./src/workflow/mod.ts",
    "./session": "./src/session/mod.ts",
    "./audit": "./src/audit/mod.ts",
    "./mt": "./src/mt/mod.ts",
    "./security": "./src/security/mod.ts",
    "./history": "./src/history/mod.ts",
    "./metrics": "./src/metrics/mod.ts",
    "./flex": "./src/flex/engine.ts",
    "./images": "./src/images/cache.ts",
    "./forms": "./src/forms/mod.ts",
    "./jobs": "./src/jobs/mod.ts",
    "./blueprints": "./src/blueprints/mod.ts",
    "./search": "./src/search/mod.ts",
    "./i18n": "./src/i18n/rtl.ts",
    "./api": "./src/api/handlers.ts",
    "./bootstrap": "./src/cli/bootstrap.ts",
    "./fresh-app": "./src/cli/fresh-app.ts"
  },
  "imports": {
    "@dune/plugin-admin": "jsr:@dune/plugin-admin@^0.24",
    "@dune/plugin-admin/admin/mount": "jsr:@dune/plugin-admin@^0.24/admin/mount",
    "@dune/plugin-admin/admin/context": "jsr:@dune/plugin-admin@^0.24/admin/context",
    "@dune/plugin-admin/admin/types": "jsr:@dune/plugin-admin@^0.24/admin/types",
    "@dune/plugin-admin/admin/auth/middleware": "jsr:@dune/plugin-admin@^0.24/admin/auth/middleware",
    "@dune/plugin-admin/admin/auth/provider": "jsr:@dune/plugin-admin@^0.24/admin/auth/provider",
    "fresh": "jsr:@fresh/core@^2",
    "preact": "npm:preact@^10",
    "preact/hooks": "npm:preact@^10/hooks",
    "preact/jsx-runtime": "npm:preact@^10/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@^10/jsx-dev-runtime",
    "preact-render-to-string": "npm:preact-render-to-string@^6",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/crypto": "jsr:@std/crypto@^1",
    "@std/encoding": "jsr:@std/encoding@^1",
    "marked": "npm:marked@^15",
    "gray-matter": "npm:gray-matter@^4",
    "@mdx-js/mdx": "npm:@mdx-js/mdx@^3",
    "sharp": "npm:sharp@^0.33",
    "nodemailer": "npm:nodemailer@^6",
    "@zip-js/zip-js": "jsr:@zip-js/zip-js@^2",
    "@db/sqlite": "jsr:@db/sqlite@^0.12",
    "postgres": "npm:postgres@^3.4",
    "ioredis": "npm:ioredis@^5",
    "polizy": "npm:polizy@^0.2.0"
  },
  "tasks": {
    "dev": "deno run -A src/cli.ts dev",
    "build": "deno run -A src/cli.ts build",
    "serve": "deno run -A src/cli.ts serve",
    "test": "deno test -A tests/",
    "check": "deno lint src/ && deno check src/**/*.ts && deno run --allow-read scripts/lint-dynamic-imports.ts",
    "dune": "deno run -A src/cli.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any",
        "require-await",
        "no-import-prefix"
      ]
    }
  }
}
